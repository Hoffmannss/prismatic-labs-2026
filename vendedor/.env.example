# Copie este arquivo para .env e preencha as chaves

# LLM API Key — verifique qual está sendo usada em 1-analyzer.js
OPENAI_API_KEY=sk-...

# OU OpenRouter (suporta vários modelos)
OPENROUTER_API_KEY=sk-or-...

# OU Groq (mais rápido e barato)
GROQ_API_KEY=gsk_...

# Notion Integration (para quando integrar o CRM)
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

