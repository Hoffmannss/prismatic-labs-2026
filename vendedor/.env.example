# Copie este arquivo para .env e preencha os segredos reais.

GROQ_API_KEY=coloque_sua_chave_groq_aqui
APIFY_API_TOKEN=coloque_seu_token_apify_aqui

# Opcional: credencial Notion (use o nome que o projeto/infra adotar)
NOTION_API_KEY=

# Controles operacionais
AUTOPILOT_ENABLED=true
AUTOPILOT_NICHO=api-automacao
AUTOPILOT_QTD=20
AUTOPILOT_MAX_ANALYZE=10
AUTOPILOT_SYNC_NOTION=true
PORT=3131
